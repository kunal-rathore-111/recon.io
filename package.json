{
  "name": "Recon",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "drizzle:generate": "cd packages/database && bunx drizzle-kit generate",
    "drizzle:push": "cd packages/database && bunx drizzle-kit push",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "web": "workspace:*"
  }
}